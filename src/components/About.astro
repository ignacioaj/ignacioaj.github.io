---
import Card from "../components/Card.astro";
import TimelineItem from "../components/TimelineItem.astro";
import EXPERIENCES from "../assets/collections/experiences.json";
import profilePicture from "../assets/profile-picture.png";
import ShortBioStepper from "../components/ShortBioStepper.astro";

const { subtitle } = Astro.props;
---

<section
  id="about"
  class="relative w-full min-h-[70vh] flex flex-col justify-center bg-center bg-cover overflow-hidden"
  style="
    background-image:
      linear-gradient(to bottom, black, rgba(0,0,0,0)),
      linear-gradient(to top, black, rgba(0,0,0,0)),
      url('/fondo-about.jpg');
    background-size: cover, cover, cover;
    background-position: center;
    background-repeat: no-repeat;
  "
>
  <div class="absolute inset-0 pointer-events-none before-glow"></div>

  <div class="section-content flex flex-col items-center text-center px-4 py-16 md:py-24 max-w-5xl w-full">

    <!-- TITLE -->
    <h2 class="text-3xl md:text-5xl font-bold text-white mb-10 md:mb-20 title-futuristic">
      About Me
    </h2>

    <!-- INTRO -->
    <section class="intro flex flex-col md:flex-row justify-center items-center gap-10 mb-16 relative z-10">

      <img
        src={profilePicture.src}
        alt="Nacho profile picture"
        class="pfp-square"
      />

      <div class="text flex-1 max-w-2xl text-left md:text-left">

        <p class="subtitle-professional text-lg md:text-xl font-semibold mb-1">
          Biomedical Engineer • Data Scientist • Developer
        </p>

        <h1 class="text-white text-3xl md:text-4xl font-bold mb-3">
          Hi, I'm Ignacio
        </h1>

        <p class="subtitle text-gray-300">
          {subtitle}
        </p>

        <!-- STACK -->
        <div class="tech-stack flex flex-wrap gap-4 mt-6 justify-start">
          {[
            { src: "https://cdn.simpleicons.org/python/40E0D0", title: "Python" },
            { src: "https://cdn.simpleicons.org/r/40E0D0", title: "R" },
            { src: "https://cdn.simpleicons.org/sqlite/40E0D0", title: "SQL" },
            { src: "https://cdn.simpleicons.org/scikitlearn/40E0D0", title: "Scikit-learn" },
            { src: "https://cdn.simpleicons.org/tensorflow/40E0D0", title: "TensorFlow / Keras" },
            { src: "https://cdn.simpleicons.org/tableau/40E0D0", title: "Tableau" },
            { src: "https://cdn.simpleicons.org/git/40E0D0", title: "Git" }
          ].map(tech => (
            <div class="tech-icon-wrapper" title={tech.title}>
              <img src={tech.src} alt={tech.title} class="tech-icon" />
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- MAIN CARDS (GRID = EQUAL HEIGHT FIX) -->
    <article class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-screen-lg z-10 items-stretch">

      <!-- SHORT BIO -->
      <Card className="text-gray-600 dark:text-gray-400 h-full flex flex-col">

        <h3 class="card-title text-center text-xl md:text-2xl mb-6 md:mb-10">
          Short Bio
        </h3>

        <div class="flex-1">
          <ShortBioStepper />
        </div>

      </Card>

      <!-- EXPERIENCE -->
      <Card className="p-8 flex flex-col text-left h-full">

        <h3 class="card-title text-center text-xl md:text-2xl mb-6 md:mb-10">
          My Experiences
        </h3>

        <ol class="relative border-s border-gray-300 dark:border-neutral-800 flex-1">
          {EXPERIENCES.map((experience, index) => (
            <TimelineItem
              title={experience.company}
              description={experience.description}
              date={experience.dates}
              isAlwaysOpen={index === 0}
              class="text-left"
            >
              <div slot="icon" class="size-full p-1" set:html={experience.svgIcon} />
            </TimelineItem>
          ))}
        </ol>

        <!-- CV BUTTON -->
        <div class="flex flex-col gap-2 mt-8">
          <h3 class="card-title text-center text-lg md:text-xl mb-4">
            Want to know more?
          </h3>

          <div class="flex justify-center">
            <a
              href="/docs/CV-IGNACIO-ATENCIA.pdf"
              download
              class="btn-turquoise"
            >
              Download CV
            </a>
          </div>
        </div>

      </Card>

    </article>
  </div>
</section>

<style>
  :root {
    --turquoise: #40E0D0;
  }

  .section-content {
    @apply w-full max-w-screen-lg mx-auto px-6 md:px-10 lg:px-16;
  }

  .title-futuristic {
    position: relative;
    display: inline-block;
  }

  .title-futuristic::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 50%;
    height: 4px;
    background: linear-gradient(90deg, #0ff, #2CA3A3);
    border-radius: 2px;
    transform: skewX(-20deg);
    transition: width 0.3s ease;
  }

  .title-futuristic:hover::after {
    width: 70%;
  }

  .pfp-square {
    width: 180px;
    height: 180px;
    border-radius: 16px;
    border: 3px solid #40e0d0;
    box-shadow: 0 0 15px rgba(64, 224, 208, 0.6), 0 0 30px rgba(64, 224, 208, 0.3);
    object-fit: cover;
  }

  .subtitle {
    font-size: 1rem;
    opacity: 0.8;
  }

  .subtitle-professional {
    color: var(--turquoise);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .tech-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
  }

  .tech-icon {
    width: 26px;
    height: 26px;
  }

  .card-title {
    color: var(--turquoise);
    font-weight: 600;
  }

  .btn-turquoise {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    font-weight: 600;
    background-color: #2CA3A3;
    color: white;
    border-radius: 0.25rem;
  }
</style>