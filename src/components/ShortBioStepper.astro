---
import bio from "../assets/collections/bio.json";

interface Step {
  question: string;
  text: string;
}

const steps = bio as Step[];
---

<div class="bio-root">
  <div id="steps"></div>
  <div class="signature hidden" id="sig">Ignacio</div>
</div>

<script is:inline define:vars={{ steps }}>
  const DATA = steps;

  const container = document.getElementById("steps");
  const sig = document.getElementById("sig");

  let current = 1;

  function typeWriter(el, text, speed = 50) {
    el.textContent = "";
    let i = 0;

    return new Promise(resolve => {
      const tick = () => {
        if (i < text.length) {
          el.textContent += text[i++];
          setTimeout(tick, speed);
        } else resolve();
      };
      tick();
    });
  }

  function createStep(i) {
    if (i >= DATA.length) {
      sig.classList.remove("hidden");
      return;
    }

    const step = document.createElement("div");
    step.className = "step";

    const btn = document.createElement("button");
    btn.className = "question";
    btn.dataset.i = i;
    btn.textContent = DATA[i].question;

    const text = document.createElement("div");
    text.className = "text";
    text.dataset.a = i;

    step.appendChild(btn);
    step.appendChild(text);
    container.appendChild(step);
  }

  async function handleClick(e) {
    const btn = e.target.closest("[data-i]");
    if (!btn) return;

    const i = Number(btn.dataset.i);
    if (i !== current) return;

    const textEl = document.querySelector(`[data-a="${i}"]`);
    if (!textEl) return;

    btn.disabled = true;

    // 1. animación de salida del botón
    btn.style.transition = "all 0.25s ease";
    btn.style.opacity = "0";
    btn.style.transform = "translateY(-6px)";
    btn.style.pointerEvents = "none";

    await new Promise(r => setTimeout(r, 250));
    btn.remove();

    // 2. escribir texto después
    await typeWriter(textEl, DATA[i].text);

    current++;
    createStep(current);
  }

  function init() {
    // primer texto automático
    const firstText = document.createElement("div");
    firstText.className = "text";
    firstText.textContent = DATA[0].text;

    container.appendChild(firstText);

    // primer botón
    createStep(1);
  }

  document.addEventListener("click", handleClick);

  init();
</script>

<style is:global>
.bio-root {
  color: #b9b9b9;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

/* contenedor de pasos */
#steps {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

/* bloque */
.step {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* texto */
.text {
  line-height: 1.6;
  font-size: 1rem;
  color: inherit;
  white-space: pre-line;
}

/* botón */
.question {
  all: unset;

  display: block;
  cursor: pointer;

  padding: 0.9rem 1.15rem;
  border-radius: 14px;

  background: rgba(64, 224, 208, 0.07);
  border: 1px solid rgba(64, 224, 208, 0.35);

  color: #40e0d0;

  font-size: 1rem;
  font-weight: 600;

  max-width: 560px;

  transition: all 0.25s ease;
}

.question:hover {
  background: rgba(64, 224, 208, 0.12);
  border-color: rgba(64, 224, 208, 0.7);
  transform: translateY(-2px);
}

.question:disabled {
  opacity: 0.5;
}

.signature {
  text-align: right;
  font-family: "Allura", cursive;
  font-size: 1.5rem;
}

.hidden {
  display: none;
}
</style>