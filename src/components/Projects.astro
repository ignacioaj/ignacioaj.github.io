---
import { Image } from "astro:assets";
import PROJECTS from "../assets/collections/projects.json";
---

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<section id="projects" class="relative pt-12 pb-24 bg-gray-900 overflow-visible">

  <!-- BACKGROUND -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0F3B3A] via-[#134B4A] to-[#1AA9A6] opacity-80"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 lg:px-16">

    <!-- TITLE -->
    <div class="text-center mb-8 md:mb-10">
      <h2 class="text-4xl md:text-5xl font-bold text-white">
        Projects
      </h2>
      <div class="mx-auto mt-4 w-24 h-[3px] bg-gradient-to-r from-[#4FD1C5] via-[#81E6D9] to-[#4FD1C5] rounded-full animate-pulse"></div>
    </div>

    <!-- CAROUSEL WRAPPER -->
    <div class="relative -mt-6 md:-mt-8">

      <!-- LEFT BUTTON -->
      <button
        id="scrollLeft"
        class="hidden absolute left-2 top-1/2 -translate-y-1/2 z-20
               w-12 h-12 flex items-center justify-center
               rounded-full bg-white/10 backdrop-blur-md
               border border-white/20 text-white
               hover:bg-white/20 hover:scale-105 transition"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
          <path d="M15 18l-6-6 6-6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- RIGHT BUTTON -->
      <button
        id="scrollRight"
        class="hidden absolute right-2 top-1/2 -translate-y-1/2 z-20
               w-12 h-12 flex items-center justify-center
               rounded-full bg-white/10 backdrop-blur-md
               border border-white/20 text-white
               hover:bg-white/20 hover:scale-105 transition"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
          <path d="M9 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- CAROUSEL -->
      <div
        id="carousel"
        class="relative z-0 flex gap-6 overflow-x-auto overflow-y-visible scrollbar-hide scroll-smooth px-10 py-10 md:py-12 snap-x snap-mandatory"
        style="
          -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
          mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
        "
      >
        {PROJECTS.map((project) => {
          const { name, description, urlImg, link } = project;

          return (
            <a
              href={link}
              target="_blank"
              class="snap-center min-w-[320px] max-w-[320px] group flex flex-col
                     rounded-3xl bg-gray-800/80 border-2 border-[#4FD1C5]/60
                     shadow-[0_0_10px_rgba(79,209,197,0.15)]
                     transition-all duration-500 ease-out
                     hover:scale-[1.05]
                     hover:shadow-[0_0_20px_rgba(79,209,197,0.35)]
                     hover:z-10 transform-gpu overflow-hidden"
            >
              <!-- IMAGE -->
              <div class="w-full h-56 overflow-hidden">
                <Image
                  src={urlImg}
                  alt={name}
                  width={400}
                  height={400}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </div>

              <!-- CONTENT -->
              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-[#4FD1C5] transition-colors">
                  {name}
                </h3>
                <p class="text-gray-200 text-sm flex-1">
                  {description}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>

  <!-- SMOOTH SCROLL -->
  <script is:inline>
    const carousel = document.getElementById("carousel");
    const left = document.getElementById("scrollLeft");
    const right = document.getElementById("scrollRight");

    const scrollAmount = 320;

    function smoothScrollBy(amount) {
      const start = carousel.scrollLeft;
      const end = start + amount;
      const duration = 520;
      const startTime = performance.now();

      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

      function animate(time) {
        const progress = Math.min((time - startTime) / duration, 1);
        const eased = easeOutCubic(progress);

        carousel.scrollLeft = start + (end - start) * eased;

        if (progress < 1) requestAnimationFrame(animate);
      }

      requestAnimationFrame(animate);
    }

    function updateArrows() {
      const canScroll = carousel.scrollWidth > carousel.clientWidth + 1;

      if (!canScroll) {
        left.style.display = "none";
        right.style.display = "none";
        return;
      }

      left.style.display = "flex";
      right.style.display = "flex";

      left.style.opacity = carousel.scrollLeft <= 0 ? "0.25" : "1";

      right.style.opacity =
        carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth
          ? "0.25"
          : "1";
    }

    left.addEventListener("click", () => smoothScrollBy(-scrollAmount));
    right.addEventListener("click", () => smoothScrollBy(scrollAmount));

    carousel.addEventListener("scroll", updateArrows);
    window.addEventListener("resize", updateArrows);
    window.addEventListener("load", updateArrows);
  </script>
</section>