---
import TimelineModal from "./TimelineItemModal.astro";

interface Props {
  title: string;
  date: string;
  description: string;
  badgeText?: string;
  isAlwaysOpen?: boolean;
}

const {
  title,
  date,
  description,
  badgeText,
  isAlwaysOpen = false
} = Astro.props;

const modalId = title.toLowerCase().replace(/\s+/g, "-");
---

<li class={`relative ${isAlwaysOpen ? "mb-10" : "mb-3"}`}>

  <!-- ICON -->
  <span class="absolute left-0 top-0 z-20 -translate-x-1/2 flex items-center justify-center size-6 bg-blue-300 rounded-full ring-8 ring-blue-100 dark:ring-blue-950/60 dark:bg-blue-800">
    <slot name="icon" />
  </span>

  <div class="ml-7 sm:ml-8 flex flex-col relative -top-3 z-0">

    <!-- TITLE -->
    <h3 class="flex items-center text-lg font-semibold text-[#40E0D0]">
      {title}

      {badgeText && (
        <span class="bg-blue-100 text-blue-800 text-sm font-medium ms-3 px-2.5 py-0.5 rounded-xs dark:bg-blue-900 dark:text-blue-300">
          {badgeText}
        </span>
      )}
    </h3>

    <!-- DATE -->
    <time class="block mb-2 text-sm text-white">
      {date}
    </time>

    <!-- CONTENT -->
    {isAlwaysOpen ? (
      <div class="mb-4 p-4 rounded-md border border-white/10 bg-white/5">
        <p class="text-sm text-white/80 leading-relaxed">
          {description}
        </p>
      </div>
    ) : (
      <>
        <button
          class="inline-flex items-center px-3 py-1 border border-white/20 rounded-md bg-white/5 text-xs text-white/70 hover:text-white w-fit mb-4"
          onclick={`document.getElementById('${modalId}').showModal(); window.ScrollLock.lock();`}
        >
          Show more
        </button>

        <TimelineModal
          id={modalId}
          title={title}
          date={date}
          description={description}
        >
          <slot name="icon" slot="icon" />
        </TimelineModal>
      </>
    )}

  </div>
</li>